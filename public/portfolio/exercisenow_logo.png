              (function() {
                var hostname = window.location.hostname;
                var isLocalhost = hostname === 'localhost' || hostname === '127.0.0.1';
                var domain = hostname.includes('.') ? '.' + hostname.split('.').slice(-2).join('.') : hostname;
                var isTabSessionActive = sessionStorage.getItem("is_tab_session_active");
                
                // Helper function to clear all googtrans cookies
                function clearGoogtransCookies() {
                  var pastDate = 'Thu, 01 Jan 1970 00:00:00 UTC';
                  document.cookie = 'googtrans=; expires=' + pastDate + '; path=/';
                  document.cookie = 'googtrans=; expires=' + pastDate + '; path=/; domain=' + hostname;
                  if (hostname.includes('.')) {
                    document.cookie = 'googtrans=; expires=' + pastDate + '; path=/; domain=' + domain;
                  }
                }
                
                // Helper function to set googtrans cookie aggressively
                function setGoogtransCookie(cookieValue) {
                  var expires = '; expires=' + new Date(Date.now() + 864e5).toUTCString(); // 1 day
                  
                  // Clear old cookies first to prevent conflicts
                  clearGoogtransCookies();
                  
                  // Set for all domain variations
                  document.cookie = 'googtrans=' + cookieValue + '; path=/' + expires;
                  document.cookie = 'googtrans=' + cookieValue + '; path=/; domain=' + hostname + expires;
                  if (hostname.includes('.')) {
                    document.cookie = 'googtrans=' + cookieValue + '; path=/; domain=' + domain + expires;
                  }
                }
                
                // First check for pending language (takes priority)
                var pendingLang = sessionStorage.getItem("pending-language");
                if (pendingLang && pendingLang !== 'en') {
                  var cookieValue = '/en/' + pendingLang;
                  setGoogtransCookie(cookieValue);
                  
                  // NOTE: Do NOT remove pending-language here. 
                  // It must remain for the React application (useLanguage hook) to detect it 
                  // and sync the Redux state (dropdown UI) correctly.
                  // The hook will handle the removal.
                  
                  console.log('[Language Debug] Pre-set googtrans for pending language: ' + cookieValue);
                  return; // Exit early
                }
                
                // Check if this is an existing tab session
                if (isTabSessionActive) {
                  // Get saved language from cookie
                  var cookies = document.cookie.split(';');
                  var savedLang = null;
                  
                  for (var i = 0; i < cookies.length; i++) {
                    var cookie = cookies[i].trim();
                    if (cookie.indexOf('preferred-language=') === 0) {
                      savedLang = cookie.substring('preferred-language='.length);
                      break;
                    }
                  }
                  
                  // If saved language exists and is not English, set googtrans cookie BEFORE page loads
                  if (savedLang && savedLang !== 'en') {
                    var cookieValue = '/en/' + savedLang;
                    setGoogtransCookie(cookieValue);
                    console.log('[Language Debug] Pre-set googtrans cookie to: ' + cookieValue);
                  }
                }
              })();
